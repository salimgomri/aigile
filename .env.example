# ==========================================
# EXAMPLE ENVIRONMENT VARIABLES
# Copy this to .env.local and fill with real values
# ==========================================

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Database (recommandé: copier depuis Supabase Dashboard > Settings > Database > Connection string URI)
# Si absent, construit à partir de SUPABASE_* ci-dessus
DATABASE_URL=

# BETTER-AUTH
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3010
NEXT_PUBLIC_APP_URL=http://localhost:3010

# URL de base (checkout, emails, portail Stripe)
# Local : http://localhost:3010
# Prod : NEXT_PUBLIC_URL=https://aigile.lu (voir PM2 + deploy/server-info.txt)
# NE PAS mettre https://aigile.lu dans .env ou .env.production à la racine
NEXT_PUBLIC_URL=http://localhost:3010

# NEXT.JS — répertoire de build (distDir)
# Vide : `.next` dans le dépôt, sauf si le projet est sous /Volumes/T9/... → sortie dans
# /Volumes/T9/aigile-next-build (même volume, dossier voisin du repo).
# Pour forcer un chemin : NEXT_DIST_DIR=/Volumes/T9/mon-dossier-next-build
# NEXT_DIST_DIR=

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# RESEND (Email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=AIgile <onboarding@resend.dev>
# Email auteur pour notifications commandes livre (KDP manuel)
AUTHOR_EMAIL=

# STRIPE (Account: aigile.lu acct_1T9oE52UwcloHrJN)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs — mode live EUR
STRIPE_PRICE_ID_PREORDER=price_1T9uQZ2UwcloHrJNf4NpuaTH   # Livre précommande €35 (active_until=2025-04-01)
STRIPE_PRICE_ID_SALE=price_1T9uQZ2UwcloHrJNk2gftA9n       # Livre vente €40 (active_from=2025-04-01)
STRIPE_PRICE_ID_PRO_MONTHLY=price_1T9vTo2UwcloHrJNuCkGkPiW   # Pro Mensuel €19.99/mois
STRIPE_PRICE_ID_PRO_ANNUAL=price_1T9vUU2UwcloHrJNjq0IHpsk    # Pro Annuel €199.99/an
STRIPE_PRICE_ID_DAY_PASS=      # Day Pass €9.99 — à créer dans Stripe
STRIPE_PRICE_ID_CREDITS_10=    # Pack 10 crédits €4.99 — à créer dans Stripe
# Rétrocompat (alias)
STRIPE_DAY_PASS_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_PACK_CREDITS_PRICE_ID=
# Livre: fin précommande (ISO date) — après cette date → prix vente €40
PREORDER_END_DATE=2025-04-25


# OPENAI
OPENAI_API_KEY=

# Google Analytics (optionnel — défaut: G-WMG8QLND8X)
NEXT_PUBLIC_GA_ID=

# CallMeBot WhatsApp (optionnel — alerte admin sur nouvelles demandes early access)
# https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_PHONE=33695549502
CALLMEBOT_APIKEY=4311337

# ADMIN (mode sans restriction: crédits illimités, accès /admin/orders)
# Emails séparés par des virgules — ne jamais afficher ces emails dans l'UI
ADMIN_EMAILS=
# Portail Stripe pour admins (sans abo perso) — ID d'un customer Stripe avec abo Pro (pour prévisualiser)
STRIPE_ADMIN_PORTAL_CUSTOMER_ID=
