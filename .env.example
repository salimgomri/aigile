# ==========================================
# EXAMPLE ENVIRONMENT VARIABLES
# Copy this to .env.local and fill with real values
# ==========================================

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Database (recommandé: copier depuis Supabase Dashboard > Settings > Database > Connection string URI)
# Si absent, construit à partir de SUPABASE_* ci-dessus
DATABASE_URL=

# BETTER-AUTH
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3010
NEXT_PUBLIC_APP_URL=http://localhost:3010

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# RESEND (Email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=AIgile <onboarding@resend.dev>

# STRIPE
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# OPENAI
OPENAI_API_KEY=

# ADMIN (mode sans restriction: crédits illimités, accès niko-niko/dora)
# Emails séparés par des virgules, ex: ADMIN_EMAILS=salim@example.com,admin@aigile.lu
ADMIN_EMAILS=
