{
  "name": "aigile",
  "version": "1.12.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' node ./node_modules/next/dist/bin/next dev --port 3010",
    "dev:clean": "rm -rf .next && NODE_OPTIONS='--dns-result-order=ipv4first' node ./node_modules/next/dist/bin/next dev --port 3010",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/next/dist/bin/next lint",
    "deploy": "./deploy_aigile.sh",
    "db:setup": "npx tsx scripts/setup-auth-db.ts",
    "db:find-region": "npx tsx scripts/find-db-region.ts",
    "simulate:book-order": "npx tsx scripts/simulate-book-order.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/supabase-js": "^2.98.0",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.2",
    "dotenv": "^16.0.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.344.0",
    "next": "^15.1.6",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-heatmap-grid": "^0.9.1",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "tailwind-merge": "^2.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "15.1.6",
    "jsdom": "^25.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.0.0",
    "typescript": "^5",
    "vitest": "^2.0.0"
  }
}
